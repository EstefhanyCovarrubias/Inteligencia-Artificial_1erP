print("¿Para qué sirve la sentencia if?")
print("Permite ejecutar código solo si una condición es verdadera.")

print("¿Qué hace la sentencia if-else?")
print("Ejecuta un bloque si la condición es True y otro si es False.")

print("¿Qué hace elif?")
print("Permite comprobar varias condiciones en orden.")

