# -----------------------------------------------------
# Operadores de comparación

print("¿Qué hace el operador != ?")
print("Compara dos valores y devuelve True si son diferentes.")

print("¿Qué hace el operador > ?")
print("Verifica si un valor es mayor que otro.")

print("¿Qué hace el operador >= ?")
print("Verifica si un valor es mayor o igual que otro.")

print("¿Qué hace el operador < ?")
print("Verifica si un valor es menor que otro.")

print("¿Qué hace el operador <= ?")
print("Verifica si un valor es menor o igual que otro.")

# -----------------------------------------------------
# Uso de las respuestas
print("¿Qué se puede hacer con el resultado de una comparación?")
print("Se puede guardar en una variable o usarlo para tomar decisiones en el programa.")

