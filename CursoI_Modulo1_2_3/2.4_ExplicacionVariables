# Ejemplo de variables (manzanas)

print("¿Para qué sirve usar varias variables en un problema?")
print("Permite guardar distintos datos y luego combinarlos en cálculos.")


# -----------------------------------------------------
# Operadores abreviados

print("¿Qué son los operadores abreviados?")
print("Son formas cortas de actualizar una variable usando su propio valor.")

print("Da un ejemplo de operador abreviado.")
print("x += 1 incrementa el valor de x en uno.")

# Comentario:
# x += 1 es equivalente a escribir:
# x = x + 1


# -----------------------------------------------------
# Conversión de unidades

print("¿Para qué sirven las variables en conversiones?")
print("Permiten guardar valores y aplicar fórmulas para convertir unidades.")

print("¿Qué hace la función round()?")
print("Redondea un número al número de decimales especificado.")

# Ejemplo:
# round(numero, 2) redondea el número a dos decimales.


