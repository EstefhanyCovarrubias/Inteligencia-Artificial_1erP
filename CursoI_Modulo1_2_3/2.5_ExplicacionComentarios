#2.5 Comentarios

# -----------------------------------------------------
#Comentarios – ¿por qué, cuándo y dónde?

print("¿Qué es un comentario en Python?")
print("Es un texto dentro del código que sirve para explicar el programa y no se ejecuta.")

print("¿Para quién están dirigidos los comentarios?")
print("Para las personas que leen o mantienen el código, no para Python.")

print("¿Cómo se escribe un comentario en Python?")
print("Se coloca el símbolo # al inicio del texto del comentario.")

# Comentario explicativo:
# Todo lo que esté después del símbolo # en una línea
# será ignorado por Python durante la ejecución.


print("¿Hasta dónde se extiende un comentario?")
print("Desde el símbolo # hasta el final de la línea.")


print("¿Cómo se escribe un comentario de varias líneas?")
print("Se coloca el símbolo # al inicio de cada línea del comentario.")


print("¿Qué es un nombre de variable auto-comentable?")
print("Es un nombre claro que explica el propósito de la variable.")

# Ejemplo conceptual
# square_area  -> buen nombre porque describe su función
# x1 o dato123 -> poco claro


# -----------------------------------------------------
# Marcar fragmentos de código

print("¿Para qué más se utilizan los comentarios?")
print("Para desactivar temporalmente partes del código durante pruebas.")

# Ejemplo explicado:
# x = 1
# y = 2
# y = y + x   <- si esta línea se comenta no se ejecutará

print("¿Qué atajo de teclado permite comentar o descomentar varias líneas?")
print("CTRL + / en Windows o CMD + / en Mac.")


# -----------------------------------------------------
#Uso correcto de comentarios

print("¿Por qué es importante usar comentarios en un programa?")
print("Porque ayudan a entender el código y facilitan su mantenimiento.")

print("¿Qué recomiendan los buenos programadores al usar comentarios?")
print("Explicar partes importantes del código y usar nombres de variables claros.")

print("¿Qué problema puede causar un comentario incorrecto?")
print("Puede confundir a quien lea el código y dificultar su comprensión.")
