# --------------------------------------------------------
# Comprensión de listas 

print("\n¿Qué es una comprensión de listas?")
print("Es una forma corta y rápida de crear listas automáticamente usando una sola línea de código.")


print("\n¿Para qué sirve la comprensión de listas?")
print("Sirve para generar listas grandes o con patrones sin usar varios ciclos.")


# Ejemplo 1
print("\nEjemplo: generar cuadrados de números")

squares = [x**2 for x in range(10)]

print("Cuadrados:", squares)


# Ejemplo 2
print("\nEjemplo: potencias de 2")

twos = [2**i for i in range(8)]

print("Potencias de 2:", twos)


# Ejemplo 3
print("\nEjemplo: filtrar números impares")

odds = [x for x in squares if x % 2 != 0]

print("Impares:", odds)


