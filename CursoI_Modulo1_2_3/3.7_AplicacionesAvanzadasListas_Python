# -----------------------------------------------------
# Aplicación: registro de temperaturas 
print("\n¿Para qué sirven las listas multidimensionales en aplicaciones reales?")
print("Sirven para guardar datos organizados como temperaturas por día y hora.")


temps = [[0.0 for h in range(24)] for d in range(31)]


# -----------------------------------------------------
# Promedio de temperatura al mediodía

print("\n¿Cómo se calcula el promedio de temperatura al mediodía?")

total = 0.0

for day in temps:
    total += day[11]   # índice 11 representa el mediodía

average = total / 31

print("Temperatura promedio al mediodía:", average)


# -----------------------------------------------------
# Temperatura más alta del mes

print("\n¿Cómo encontrar la temperatura más alta del mes?")

highest = -100.0

for day in temps:
    for temp in day:
        if temp > highest:
            highest = temp

print("Temperatura más alta:", highest)


# -----------------------------------------------------
# Contar días calurosos

print("\n¿Cómo contar días donde la temperatura al mediodía supera 20°C?")

hot_days = 0

for day in temps:
    if day[11] > 20.0:
        hot_days += 1

print("Días calurosos:", hot_days)


# -----------------------------------------------------
# Listas tridimensionales

print("\n¿Qué es una lista tridimensional?")
print("Es una lista que contiene listas que a su vez contienen otras listas.")


print("\nEjemplo: sistema de habitaciones de hotel")


# 3 edificios, 15 pisos, 20 habitaciones
rooms = [[[False for r in range(20)] for f in range(15)] for t in range(3)]

print("Hotel creado con habitaciones disponibles")


# Reservar habitación
rooms[1][9][13] = True

print("Habitación reservada en edificio 2, piso 10, habitación 14")


# Desocupar habitación
rooms[0][4][1] = False

print("Habitación liberada en edificio 1, piso 5, habitación 2")


# Verificar habitaciones libres
print("\n¿Cómo contar habitaciones disponibles en un piso?")

vacancy = 0

for room_number in range(20):
    if not rooms[2][14][room_number]:
        vacancy += 1

print("Habitaciones disponibles:", vacancy)