# 3. Cola (Queue) - FIFO

# Definimos una excepción personalizada para la cola
class QueueError(Exception):
    pass

class Queue:
    def __init__(self):
        # Lista privada que almacena los elementos de la cola
        self.__queue_list = []

    def put(self, element):
        # Agregar un elemento al principio de la lista (final de la cola)
        self.__queue_list.insert(0, element)

    def get(self):
        # Sacar el elemento del final de la lista (inicio de la cola)
        if not self.__queue_list:
            raise QueueError("Queue error")  # Excepción si la cola está vacía
        return self.__queue_list.pop()  # .pop() quita el último elemento

    def is_empty(self):
        # Retorna True si la cola está vacía, False si tiene elementos
        return len(self.__queue_list) == 0

# Ejemplo de uso:
queue = Queue()
queue.put(1)
queue.put("perro")
queue.put(False)
print(queue.get())  # 1 (FIFO)
print(queue.get())  # "perro"
print(queue.get())  # False

# Intentar extraer de una cola vacía genera excepción
try:
    queue.get()
except QueueError as e:
    print(e)  # Queue error

# Verificar si la cola está vacía
print("Cola vacía?", queue.is_empty())  # True