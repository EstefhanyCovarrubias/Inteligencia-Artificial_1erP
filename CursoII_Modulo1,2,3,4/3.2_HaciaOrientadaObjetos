# 2. Pila con contador y suma (extensión de Stack)

class AddingStack(Stack):
    def __init__(self):
        # Primero, inicializamos la superclase Stack
        Stack.__init__(self)
        # Variable privada para sumar los elementos de la pila
        self.__sum = 0
        # Variable privada para contar las operaciones push/pop
        self.__counter = 0

    # Sobrescribimos push para agregar funcionalidad extra
    def push(self, val):
        self.__sum += val  # Sumamos el valor al total
        self.__counter += 1  # Contamos la operación
        Stack.push(self, val)  # Llamamos al push original de Stack

    # Sobrescribimos pop para restar del total y aumentar contador
    def pop(self):
        val = Stack.pop(self)  # Extraemos el elemento usando el método de la superclase
        self.__sum -= val       # Restamos el valor de la suma total
        self.__counter += 1     # Contamos la operación
        return val

    # Método para obtener la suma actual de la pila
    def get_sum(self):
        return self.__sum

    # Método para obtener el número total de operaciones push/pop
    def get_counter(self):
        return self.__counter

# Ejemplo de uso:
stack2 = AddingStack()
stack2.push(5)
stack2.push(10)
stack2.push(15)
print("Suma:", stack2.get_sum())      # 30
print("Operaciones:", stack2.get_counter())  # 3
stack2.pop()
print("Suma después de pop:", stack2.get_sum())  # 15
print("Operaciones totales:", stack2.get_counter())  # 4


