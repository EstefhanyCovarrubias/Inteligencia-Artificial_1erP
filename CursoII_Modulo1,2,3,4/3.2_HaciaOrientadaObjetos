# 1. Pila básica (Stack) - LIFO
class Stack:
    def __init__(self):
        # Lista privada que almacenará los elementos de la pila
        self.__stack_list = []

    def push(self, val):
        # Método público para agregar un elemento al tope de la pila
        self.__stack_list.append(val)

    def pop(self):
        # Método público para quitar y devolver el elemento del tope
        if not self.__stack_list:
            raise IndexError("Stack vacía")  # Protección: no se puede extraer de una pila vacía
        return self.__stack_list.pop()  # .pop() de lista elimina y devuelve el último elemento

# Ejemplo de uso:
stack1 = Stack()
stack1.push(10)
stack1.push(20)
stack1.push(30)
print(stack1.pop())  # 30
print(stack1.pop())  # 20


