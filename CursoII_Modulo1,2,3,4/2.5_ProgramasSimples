# LAB 5: encontrar palabra dentro de otra cadena
# ============================================================

word = "donor"
text = "Nabucodonosor".lower()

pos = 0
found = True

for ch in word:
    pos = text.find(ch, pos)
    if pos == -1:
        found = False
        break
    pos += 1

print("palabra encontrada:", "si" if found else "no")