# ------------------------------------------------------------
# 1. cifrado cesar (version simple)
# cada letra se mueve una posicion en el alfabeto
# ------------------------------------------------------------
message = "AVE CAESAR"
cipher = ""

for ch in message:
    if not ch.isalpha():
        continue
    ch = ch.upper()
    code = ord(ch) + 1
    if code > ord('Z'):
        code = ord('A')
    cipher += chr(code)

print("cifrado:", cipher)


# ------------------------------------------------------------
# 2. descifrar cifrado cesar
# ------------------------------------------------------------
message = cipher
plain = ""

for ch in message:
    code = ord(ch) - 1
    if code < ord('A'):
        code = ord('Z')
    plain += chr(code)

print("descifrado:", plain)


