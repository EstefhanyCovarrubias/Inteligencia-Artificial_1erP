# 3. procesador de numeros
# suma numeros escritos en una linea
# ------------------------------------------------------------
line = "10 20 30 5.5"
numbers = line.split()

total = 0

for n in numbers:
    total += float(n)

print("suma:", total)


# ------------------------------------------------------------
# 4. validador simple de IBAN
# ------------------------------------------------------------
iban = "GB72HBZU70067212125300"

iban = iban.replace(" ", "")

iban = iban[4:] + iban[:4]

iban2 = ""

for ch in iban:
    if ch.isdigit():
        iban2 += ch
    else:
        iban2 += str(ord(ch) - 55)

if int(iban2) % 97 == 1:
    print("IBAN valido")
else:
    print("IBAN invalido")


# ============================================================
# LAB 1: cifrado cesar mejorado
# permite desplazamiento 1..25 y mantiene mayusculas/minusculas
# ============================================================

text = "abcxyzABCxyz 123"
shift = 2
result = ""

for ch in text:
    if ch.isalpha():
        base = ord('A') if ch.isupper() else ord('a')
        # calcula desplazamiento dentro del alfabeto
        result += chr((ord(ch) - base + shift) % 26 + base)
    else:
        result += ch

print("cifrado mejorado:", result)


