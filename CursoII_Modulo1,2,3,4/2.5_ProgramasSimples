# LAB 4: digito de la vida
# ============================================================

birth = "19991229"

total = sum(int(d) for d in birth)

while total > 9:   # se repite hasta obtener un solo digito
    total = sum(int(d) for d in str(total))

print("digito de la vida:", total)


