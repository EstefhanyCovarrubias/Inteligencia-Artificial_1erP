# 3.4 Métodos y constructores en Python


# -----------------------------------
# Métodos básicos
class Classy:
    def method(self, par):
        """
        Método normal:
        - 'self' permite acceder al objeto que invoca el método.
        - par: argumento adicional que se pasa al método.
        """
        print("método:", par)

# Crear objeto
obj = Classy()
obj.method(1)
obj.method(2)
obj.method(3)
# Output:
# método: 1
# método: 2
# método: 3

# -----------------------------------
# Acceso a variables de clase y de instancia
class Classy2:
    varia = 2  # Variable de clase

    def method(self):
        # 'self.var' será una variable de instancia agregada fuera de la clase
        print(self.varia, self.var)

obj2 = Classy2()
obj2.var = 3  # Variable de instancia agregada dinámicamente
obj2.method()
# Output: 2 3

# -----------------------------------
# Invocación de otros métodos dentro de la clase

class Classy3:
    def other(self):
        print("otro")

    def method(self):
        print("método")
        self.other()  # Llamada a otro método usando self

obj3 = Classy3()
obj3.method()
# Output:
# método
# otro

# -----------------------------------
# Constructor (__init__)

class ExampleConstructor:
    def __init__(self, val="objeto"):
        """
        Constructor:
        - Se invoca automáticamente al crear un objeto.
        - No devuelve valores.
        - Se usa para inicializar variables de instancia.
        """
        self.val = val

obj4 = ExampleConstructor()
print(obj4.val)  # Output: objeto

# Constructor con argumento por defecto
obj5 = ExampleConstructor("nuevo objeto")
print(obj5.val)  # Output: nuevo objeto

