# 5. Métodos y variables privadas
# -----------------------------------
class ClassyPrivate:
    def visible(self):
        print("visible")

    def __hidden(self):
        print("oculto")

obj6 = ClassyPrivate()
obj6.visible()  # Output: visible

try:
    obj6.__hidden()  # Fallará, método privado
except:
    print("fallido")  # Output: fallido

# Acceso a método privado con name mangling
obj6._ClassyPrivate__hidden()  # Output: oculto

# -----------------------------------
# 6. Propiedades útiles de clases y objetos
# -----------------------------------
print("obj.__dict__:", obj6.__dict__)  # Diccionario de variables de instancia
print("Clase __name__:", ClassyPrivate.__name__)  # Nombre de la clase
print("Clase __module__:", ClassyPrivate.__module__)  # Módulo de definición
print("Clase __bases__:", ClassyPrivate.__bases__)  # Superclases

