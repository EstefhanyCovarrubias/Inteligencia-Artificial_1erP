# LAB: Clase Weeker

class WeekDayError(Exception):
    pass

class Weeker:
    __days = ["Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom"]

    def __init__(self, day):
        if day not in Weeker.__days:
            raise WeekDayError("Día inválido")
        self.__day_index = Weeker.__days.index(day)

    def __str__(self):
        return Weeker.__days[self.__day_index]

    def add_days(self, n):
        self.__day_index = (self.__day_index + n) % 7

    def subtract_days(self, n):
        self.__day_index = (self.__day_index - n) % 7

w = Weeker("Lun")
print(w)  # Lun
w.add_days(1)
print(w)  # Mar
w.subtract_days(3)
print(w)  # Dom

