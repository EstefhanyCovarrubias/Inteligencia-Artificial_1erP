# Introspección y reflexión
class Introspect:
    def __init__(self):
        self.a = 1
        self.integer = 4
        self.b = 2
        self.i = 3
        self.z = 5
        self.ireal = 3.5

def incIntsI(obj):
    """
    Función que incrementa todos los atributos enteros cuyo
    nombre comienza con 'i' en el objeto recibido.
    """
    print("Antes:", obj.__dict__)
    for attr in obj.__dict__:
        if attr.startswith('i'):
            val = getattr(obj, attr)  # Obtener valor dinámicamente
            if isinstance(val, int):
                setattr(obj, attr, val + 1)  # Incrementar valor
    print("Después:", obj.__dict__)

obj_int = Introspect()
incIntsI(obj_int)
# Output:
# Antes: {...}
# Después: {... con 'i' incrementados en 1}

