# LAB: Clase Triangle

class Triangle:
    def __init__(self, p1, p2, p3):
        self.__points = [p1, p2, p3]

    def perimeter(self):
        a = self.__points[0].distance_from_point(self.__points[1])
        b = self.__points[1].distance_from_point(self.__points[2])
        c = self.__points[2].distance_from_point(self.__points[0])
        return a + b + c

tri = Triangle(Point(0,0), Point(1,0), Point(1,1))
print(tri.perimeter())  # 3.414213562373095