    ["###",
     "  #",
     "  #",
     "  #",
     "  #"],

    ["###",
     "# #",
     "###",
     "# #",
     "###"],

    ["###",
     "# #",
     "###",
     "  #",
     "###"]
]

num = input("\ningresa un numero: ")

# se imprime fila por fila para formar los digitos
for row in range(5):
    line = ""
    for digit in num:
        line += digits[int(digit)][row] + " "
    print(line)