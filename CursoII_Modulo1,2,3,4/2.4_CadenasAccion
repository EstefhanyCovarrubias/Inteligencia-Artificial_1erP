# ============================================================
# comparacion de cadenas, ordenamiento y conversion
# ============================================================

# las cadenas se pueden comparar usando operadores normales
print("alpha" == "alpha")
print("alpha" != "Alpha")
print("beta" > "Beta")     # mayusculas tienen menor codigo que minusculas
print("alpha" < "alphabet")  # si una es prefijo de otra, la mas larga es mayor


# ------------------------------------------------------------
# ordenamiento de listas de cadenas
# ------------------------------------------------------------

greek = ['omega', 'alpha', 'pi', 'gamma']

# sorted() crea una nueva lista ordenada
sorted_list = sorted(greek)

print("lista original:", greek)
print("lista ordenada:", sorted_list)

# sort() ordena la lista directamente
greek.sort()
print("lista despues de sort():", greek)


