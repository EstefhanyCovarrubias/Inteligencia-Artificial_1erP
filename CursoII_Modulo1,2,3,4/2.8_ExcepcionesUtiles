# LABORATORIO: leer enteros de forma segura

def read_int(prompt, min_val, max_val):
    while True:
        try:
            value = int(input(prompt))

            # verificar que el numero este dentro del rango
            if value < min_val or value > max_val:
                print(f"Error: el valor no esta dentro del rango permitido ({min_val}..{max_val})")
                continue

            return value  # numero valido

        except ValueError:
            # ocurre si el usuario escribe texto
            print("Error: entrada incorrecta")


# uso de la funcion
numero = read_int("Ingresa un numero entre -10 a 10: ", -10, 10)
print("El numero es:", numero)