# -----------------------------------------------------
#Comentarios – ¿por qué, cuándo y dónde?

print("¿Qué es un comentario en Python?")
print("Es un texto en el código que sirve para explicar el programa y Python lo ignora al ejecutarlo.")

print("¿Para qué sirven los comentarios?")
print("Para explicar el funcionamiento del código, documentarlo y ayudar a quienes lo lean.")

print("¿Cómo se escribe un comentario en Python?")
print("Se coloca el símbolo # al inicio del texto del comentario.")

# Todo lo que esté después del símbolo # en una línea
# es ignorado por Python durante la ejecución.

print("¿Hasta dónde se extiende un comentario?")
print("Desde el símbolo # hasta el final de la línea.")

print("¿Cómo se escriben comentarios de varias líneas?")
print("Se coloca el símbolo # al inicio de cada línea.")

print("¿Qué es un nombre de variable auto-comentable?")
print("Un nombre claro que describe su función, como square_area.")


# -----------------------------------------------------
# Marcar fragmentos de código

print("¿Para qué más se pueden usar los comentarios?")
print("Para desactivar temporalmente partes del código durante pruebas.")

# Ejemplo conceptual:
# x = 1
# y = 2
# y = y + x   <- si está comentado no se ejecuta

print("¿Qué atajo permite comentar varias líneas rápidamente?")
print("CTRL + / en Windows o CMD + / en Mac.")


